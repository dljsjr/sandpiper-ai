{
  "name": "sandpiper-ai",
  "version": "0.0.1",
  "author": "Doug Stephen <dljs.jr@dougstephenjr.com>",
  "private": true,
  "scripts": {
    "check:biome-fmt": "bunx --bun @biomejs/biome format",
    "check:biome-lint": "bunx --bun @biomejs/biome lint",
    "check:biome-check": "bunx --bun @biomejs/biome check",
    "check:tsc": "tsc --noEmit",
    "check:ast-grep": "ast-grep scan",
    "check": "bun run check:tsc && bun run check:biome-check",
    "clean": "rm -rf {.,**}/{node_modules,dist,.*cache,*.d.ts,*.tsbuildinfo}",
    "sandpiper-cli": "sandpiper"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "extensions/*",
      "devtools/"
    ],
    "catalogs": {
      "bun": {
        "bun": "1.3.11",
        "@types/bun": "1.3.11"
      },
      "cli": {
        "commander": "14.0.3",
        "@commander-js/extra-typings": "14.0.0"
      },
      "pi": {
        "@mariozechner/pi-coding-agent": "0.61.0",
        "@silvia-odwyer/photon-node": "0.3.4"
      },
      "ts": {
        "typescript": "5.9.3"
      },
      "testing": {
        "vitest": "4.1.0"
      },
      "tooling": {
        "@biomejs/biome": "2.4.6",
        "ascii-motion-mcp": "file:../ascii-motion-mcp",
        "mcporter": "0.7.3",
        "canvas": "3.2.1"
      }
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "sandpiper-ai-cli": "workspace:*",
    "supports-color": "^10.2.2"
  },
  "description": "To install dependencies:",
  "main": "sandpiper-design-iterative.js",
  "devDependencies": {
    "typescript": "catalog:ts",
    "vitest": "catalog:testing"
  },
  "license": "ISC",
  "type": "commonjs"
}
