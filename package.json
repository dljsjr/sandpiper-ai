{
  "name": "sandpiper-ai",
  "version": "0.0.1",
  "author": "Doug Stephen <dljs.jr@dougstephenjr.com>",
  "private": true,
  "scripts": {
    "preinstall": "bash devtools/vendor.sh --if-missing && bash devtools/preinstall.sh && bun --workspaces --if-present preinstall",
    "postinstall": "bash devtools/postinstall.sh",
    "check:biome-fmt": "bunx --bun @biomejs/biome format",
    "check:biome-lint": "bunx --bun @biomejs/biome lint",
    "check:biome-check": "bunx --bun @biomejs/biome check",
    "check:tsc": "tsc --noEmit",
    "check:ast-grep": "ast-grep scan",
    "check": "bun run check:tsc && bun run check:biome-check",
    "build": "bun --filter sandpiper-ai-cli build",
    "vendor": "bash devtools/vendor.sh",
    "clean": "bun devtools/clean.ts",
    "sandpiper-dev": "bun run --bun ./packages/cli/pi_wrapper.ts"
  },
  "bin": {
    "sandpiper": "./dist/sandpiper",
    "sandpiper-tasks": "./packages/sandpiper-tasks-cli/dist/sandpiper-tasks"
  },
  "files": [
    "./dist"
  ],
  "keywords": [
    "pi-package"
  ],
  "piConfig": {
    "name": "sandpiper",
    "configDir": ".sandpiper",
    "bin": "sandpiper"
  },
  "pi": {
    "extensions": [
      "./extensions/system.ts",
      "./extensions/shell-relay",
      "./extensions/web-fetch"
    ],
    "skills": [
      "./skills/sandpiper",
      "./skills/third-party"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "extensions/*",
      "devtools/"
    ],
    "catalogs": {
      "bun": {
        "bun": "1.3.11"
      },
      "cli": {
        "commander": "14.0.3",
        "@commander-js/extra-typings": "14.0.0",
        "chalk": "5.6.2",
        "supports-color": "10.2.2"
      },
      "pi": {
        "@mariozechner/pi-coding-agent": "0.65.0",
        "@mariozechner/pi-tui": "0.65.0",
        "@silvia-odwyer/photon-node": "0.3.4",
        "@sinclair/typebox": "0.34.48"
      },
      "ts": {
        "typescript": "6.0.2",
        "@types/node": "*",
        "@types/bun": "1.3.11"
      },
      "web": {
        "@mozilla/readability": "0.6.0",
        "jsdom": "29.0.1",
        "turndown": "7.2.2",
        "@types/jsdom": "28.0.1",
        "@types/turndown": "5.0.6"
      },
      "testing": {
        "vitest": "4.1.1"
      },
      "tooling": {
        "@biomejs/biome": "2.4.6",
        "ascii-motion-mcp": "file:../ascii-motion-mcp",
        "mcporter": "0.7.3",
        "canvas": "3.2.2"
      }
    }
  },
  "dependencies": {
    "chalk": "catalog:cli",
    "sandpiper-ai-cli": "workspace:*",
    "sandpiper-ai-core": "workspace:*",
    "sandpiper-tasks-cli": "workspace:*",
    "supports-color": "catalog:cli"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "catalog:pi",
    "@mariozechner/pi-tui": "catalog:pi",
    "@sinclair/typebox": "catalog:pi"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "catalog:cli",
    "@types/node": "catalog:ts",
    "commander": "catalog:cli",
    "mcporter": "catalog:tooling",
    "typescript": "catalog:ts",
    "vitest": "catalog:testing"
  },
  "license": "MIT",
  "type": "module"
}
