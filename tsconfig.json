{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Type definitions and emit
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],

    // Resolve Pi framework imports for single-file extensions that run
    // in pi's jiti environment (no package.json of their own)
    "paths": {
      "@mariozechner/pi-coding-agent": [
        "./node_modules/@mariozechner/pi-coding-agent"
      ],
      "@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
      "sandpiper-ai-core": ["./packages/core/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "**/dist",
    // Dev-only scripts that use non-standard imports or generated code
    "draw-sandpiper.ts",
    "devtools/ascii-motion.ts",
    // Config files
    "vitest.config.ts",
    "**/vitest.config.ts",
    // JS output files
    "./*.js"
  ]
}
