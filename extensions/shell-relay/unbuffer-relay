#!/usr/bin/env tclsh
#
# unbuffer-relay — PTY wrapper with exit code propagation
#
# Like `unbuffer` from the expect package, wraps a command in a PTY so that
# isatty(stdout) returns true, preserving ANSI colors. Unlike stock `unbuffer -p`,
# this script properly propagates the child process's exit code.
#
# Usage:
#   unbuffer-relay [-p] command [args...]
#
# Options:
#   -p  Pipeline mode: forward stdin to the child process
#
# Requires: tclsh + expect package
#
# References: FR-15, shell-relay PRD

package require Expect

set pipeline 0
if {[lindex $argv 0] eq "-p"} {
    set pipeline 1
    set argv [lrange $argv 1 end]
}

if {[llength $argv] == 0} {
    puts stderr "Usage: unbuffer-relay \[-p\] command \[args...\]"
    exit 1
}

log_user 1
set timeout -1

spawn -noecho {*}$argv
set child $spawn_id

if {$pipeline} {
    # Disable PTY echo in pipeline mode to prevent input duplication
    stty -echo < $spawn_out(slave,name)

    # Read all of stdin and send to child
    fconfigure stdin -translation binary -buffering full
    set data [read stdin]
    if {[string length $data] > 0} {
        exp_send -i $child -- $data
    }
    # Send EOF (Ctrl+D) to signal end of input
    exp_send -i $child "\x04"
}

# Wait for child to finish
catch {expect -i $child eof}

# Capture exit status
set exit_code 0
catch {
    set wait_result [wait -i $child]
    set exit_code [lindex $wait_result 3]
}

exit $exit_code
