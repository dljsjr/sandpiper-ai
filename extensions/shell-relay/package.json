{
  "name": "shell-relay",
  "version": "0.0.1",
  "type": "module",
  "description": "Pi extension: shared terminal session between user and agent via Zellij",
  "bin": {
    "shell_relay": "./dist/shell-relay",
    "unbuffer-relay": "./unbuffer-relay",
    "ghost-attach": "./ghost-attach"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "catalog:pi",
    "@sinclair/typebox": "catalog:pi"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "mkdir -p dist && tsc && bun build --production --minify --target=node ./src/index.ts --outfile ./dist/shell-relay",
    "preinstall": "mkdir -p dist && bun build --production --minify --target=node ./src/index.ts --outfile ./dist/shell-relay"
  },
  "pi": {
    "extensions": [
      "./dist/shell-relay"
    ]
  }
}
