{
  "$schema": "https://raw.githubusercontent.com/steipete/mcporter/main/mcporter.schema.json",
  "mcpServers": {
    "ascii-motion": {
      "command": "bunx",
      "args": ["ascii-motion-mcp", "--live", "--project-dir", "/Users/dstephen/git/sandpiper-ai"],
      "lifecycle": "keep-alive",
      "logging": { "daemon": { "enabled": true } }
    },
    "dash": {
      "command": "mise",
      "args": [
        "x",
        "uv@latest",
        "--",
        "uvx",
        "--from",
        "git+https://github.com/Kapeli/dash-mcp-server.git",
        "dash-mcp-server"
      ],
      "lifecycle": "keep-alive",
      "logging": { "daemon": { "enabled": true } }
    }
  },
  "imports": []
}
