{
  "name": "sandpiper-ai-cli",
  "version": "0.0.1",
  "type": "module",
  "author": {
    "name": "Doug Stephen",
    "email": "dljs.jr@dougstephenjr.com"
  },
  "bin": {
    "sandpiper": "./dist/sandpiper"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "catalog:pi"
  },
  "peerDependencies": {
    "@silvia-odwyer/photon-node": "catalog:pi"
  },
  "scripts": {
    "build": "mkdir -p dist && tsc && bun build --production --minify --target=node ./pi_wrapper.ts --outfile ./dist/sandpiper",
    "copy-assets": "bun run --target bun ./copy_pi_assets.ts",
    "preinstall": "mkdir -p dist && bun build --production --minify --target=node ./pi_wrapper.ts --outfile ./dist/sandpiper && bun copy-assets && ./locatePi.sh"
  }
}
