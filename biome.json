{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": [
      "*.ts",
      "*.js",
      "**/*.ts",
      "**/*.js",
      "**/*.json",
      "!node_modules",
      "!**/node_modules",
      "!dist",
      "!**/dist",
      "!draw-sandpiper.ts",
      "!devtools/ascii-motion.ts"
    ]
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "lineWidth": 120
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ]
}
